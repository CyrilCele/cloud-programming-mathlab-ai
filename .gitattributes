###############################################################################
# Line Endings
###############################################################################

* text=auto

*.sh text eol=lf
*.tf text eol=lf
*.tftpl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

###############################################################################
# Binary Files
###############################################################################

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary

###############################################################################
# Linguist
###############################################################################

*.tf linguist-language=HCL